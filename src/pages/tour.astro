---
import Layout from "@/layouts/Layout.astro";
import TourRegistration from "@/components/TourRegistration";
import { tours } from "@/lib/catalog";

const priceMajor = Math.round(tours.pricePerDay / 100);
---

<Layout title={`${tours.title} — Yachad`} description={tours.subtitle}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,700;12..96,800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="tourpage">
    <!-- HERO -->
    <section class="hero">
      <div class="sky"></div><div class="glow"></div><div class="scrim"></div><div class="grain"></div>
      <div class="container">
        <header class="bar"><div class="mark">Yachad<span>.</span></div><div class="partner">{tours.title}</div></header>
      </div>
      <div class="container hero-wrap">
        <div class="hero-inner">
          <div class="eyebrow">{tours.title}</div>
          <h1>Explore the world of mechinot, <em>up close.</em></h1>
          <p class="sub">Each tour day visits three different mechinot — meet the educational teams, learn how each program works, and experience campus life firsthand before you apply.</p>
          <p class="step">For students entering grades 10–12 and their families.</p>
          <div class="cta">
            <a class="btn btn-go" href="#book">Register &amp; Pay <span class="price">· ₪{priceMajor}</span></a>
            <a class="btn btn-ghost" href="#about">See the tour ↓</a>
          </div>
          <div class="meta-line">{tours.days.map((d) => <span>{d.date}</span>)}<span>Times TBC</span></div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="about" id="about">
      <div class="container">
        <div class="reveal">
          <div class="eyebrow">About the tour</div>
          <h2>Three different mechinot, in a single day.</h2>
          <p class="lede">Yachad — meaning “together” — connects Jewish teens from around the world with Israel’s Mechina gap-year programs. The Summer Mechinot Tour is for students considering a Mechina who want to explore different programs, meet their educational teams, and experience campus life firsthand before applying.</p>
        </div>
        <div class="grid">
          <article class="card reveal"><div class="ph a"></div><div class="card-txt"><h3>Three mechinot</h3><p>Each day visits three different programs, each with its own approach.</p></div></article>
          <article class="card reveal"><div class="ph b"></div><div class="card-txt"><h3>Meet the teams</h3><p>Talk with the educators behind each Mechina and ask your questions.</p></div></article>
          <article class="card reveal"><div class="ph c"></div><div class="card-txt"><h3>Campus life</h3><p>Walk the campuses and get a real feel for the experience.</p></div></article>
          <article class="card reveal"><div class="ph d"></div><div class="card-txt"><h3>All included</h3><p>Transport between every location, a group lunch, and snacks along the way.</p></div></article>
        </div>
        <div class="cost-callout reveal"><b>₪{priceMajor} per participant, per tour day.</b> The fee is subsidized by the Yachad Program and includes transportation, lunch, and refreshments throughout the day.</div>
        <div class="about-cta reveal">
          <a class="btn btn-go" href="#book">Register &amp; Pay <span class="price">· ₪{priceMajor}</span></a>
          <span class="note">We recommend a full day to see all three Mechinot — and you’re welcome to join both days for a broader view.</span>
        </div>
      </div>
    </section>

    <!-- BOOKING -->
    <section class="book" id="book">
      <div class="container">
        <div class="head reveal">
          <div class="eyebrow">Register &amp; Pay</div>
          <h2>Book your tour day(s)</h2>
          <p>Pick your day(s) and how many are coming. ₪{priceMajor} per person, per day.</p>
        </div>
        <div class="book-card reveal">
          <TourRegistration
            client:load
            days={tours.days}
            priceMajor={priceMajor}
            maxPerDay={tours.maxPerDay}
            currencySymbol="₪"
          />
        </div>
      </div>
    </section>

    <!-- DETAILS -->
    <section class="details" id="details">
      <div class="container">
        <div class="eyebrow reveal">Good to know</div>
        <h2 class="reveal">Before you register</h2>
        <div class="det-grid">
          <div class="det reveal">
            <h3>Participation terms</h3>
            <ul>
              <li>Open to students entering 10th, 11th or 12th grade, plus their family members and accompanying guests.</li>
              <li>Registration is required for each participant.</li>
              <li>The ₪{priceMajor} fee per person, per day applies to all participants.</li>
              <li>Registration and payment must be completed by July 5, 2026.</li>
            </ul>
          </div>
          <div class="det reveal">
            <h3>How to register</h3>
            <ul>
              <li>Enter the student’s information and a guardian’s contact details so we can send important updates.</li>
              <li>During registration you’ll choose your tour day(s) and how many guests join each day.</li>
            </ul>
          </div>
          <div class="det reveal">
            <h3>Cancellation &amp; refunds</h3>
            <ul>
              <li>Cancel by July 5, 2026 for a full refund.</li>
              <li>After July 5, 2026, fees are non-refundable.</li>
              <li>If a tour is canceled by the organizers, you receive a full refund.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container">
        <div class="mark">Yachad<span>.</span></div>
        <p>Questions about the {tours.title}? <a href="#">WhatsApp the Yachad team</a>.</p>
        <p class="small">{tours.deadline} · A program of Yachad with Masa</p>
      </div>
    </footer>
  </div>
</Layout>

<style is:global>
  .tourpage {
    --ink:#16140e; --sand:#f4efe3; --sand-deep:#ece3d0; --paper:#fffaf4;
    --gold:#eaa33d; --olive:#6e854e; --bad:#c0532f;
    --display:"Bricolage Grotesque",-apple-system,system-ui,sans-serif;
    --body:"Inter",-apple-system,system-ui,sans-serif;
    --fs-h1:clamp(2.2rem,1.6rem + 2.6vw,5.5rem);
    --fs-h2:clamp(1.65rem,1.25rem + 1.7vw,3.2rem);
    --fs-lead:clamp(1.05rem,1rem + .45vw,1.45rem);
    --fs-body:clamp(.98rem,.93rem + .2vw,1.12rem);
    --pad-sec:clamp(2.75rem,7vw,6.5rem);
    --maxw:clamp(1140px,82vw,1600px);
    font-family:var(--body); background:var(--ink); color:var(--sand);
    line-height:1.5; -webkit-font-smoothing:antialiased;
  }
  .tourpage *{box-sizing:border-box;margin:0;padding:0}
  .tourpage .container{width:100%;max-width:var(--maxw);margin-inline:auto;padding-inline:clamp(1.25rem,5vw,2.5rem)}
  .tourpage [id]{scroll-margin-top:1.5rem}
  .tourpage .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s cubic-bezier(.2,.7,.2,1),transform .7s cubic-bezier(.2,.7,.2,1)}
  .tourpage .reveal.in{opacity:1;transform:none}

  /* HERO */
  .tourpage .hero{position:relative;min-height:100svh;display:flex;flex-direction:column;overflow:hidden;isolation:isolate}
  .tourpage .sky,.tourpage .glow,.tourpage .scrim,.tourpage .grain{position:absolute;inset:0;z-index:-1}
  .tourpage .sky{background:linear-gradient(168deg,rgba(207,133,48,.4),rgba(51,50,31,.85)),radial-gradient(120% 80% at 70% 10%, #4a3b22, #16140e 70%)}
  .tourpage .glow{background:radial-gradient(115% 75% at 72% 16%,rgba(234,163,61,.4),rgba(234,163,61,0) 55%)}
  .tourpage .scrim{background:linear-gradient(to top,rgba(22,20,14,.92) 4%,rgba(22,20,14,.5) 34%,rgba(22,20,14,0) 62%)}
  .tourpage .bar{display:flex;align-items:baseline;justify-content:space-between;gap:1rem;padding-block:clamp(1.1rem,4vw,1.7rem)}
  .tourpage .mark{font-family:var(--display);font-weight:800;font-size:clamp(1.35rem,1.2rem + .4vw,1.9rem);letter-spacing:-.02em}
  .tourpage .mark span{color:var(--gold)}
  .tourpage .partner{font-size:clamp(.66rem,.6rem + .15vw,.82rem);letter-spacing:.16em;text-transform:uppercase;color:rgba(244,239,227,.78);white-space:nowrap}
  .tourpage .hero-wrap{margin-top:auto;padding-bottom:clamp(1.8rem,5vw,3.5rem)}
  .tourpage .hero-inner{max-width:clamp(40rem,56vw,56rem)}
  .tourpage .eyebrow{display:inline-flex;align-items:center;gap:.55rem;font-size:clamp(.72rem,.66rem + .15vw,.86rem);letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:1.1rem}
  .tourpage .eyebrow::before{content:"";width:26px;height:1px;background:currentColor}
  .tourpage h1{font-family:var(--display);font-weight:700;font-size:var(--fs-h1);line-height:1.02;letter-spacing:-.025em;margin-bottom:1.1rem}
  .tourpage h1 em{font-style:normal;color:var(--gold)}
  .tourpage .sub{font-size:var(--fs-lead);color:rgba(244,239,227,.84);max-width:46ch;margin-bottom:1.6rem}
  .tourpage .step{font-size:var(--fs-body);margin-bottom:.85rem;color:rgba(244,239,227,.9)}
  .tourpage .cta{display:flex;flex-wrap:wrap;align-items:center;gap:.7rem .9rem}
  .tourpage .btn{font-family:var(--body);font-weight:600;font-size:clamp(1rem,.95rem + .15vw,1.12rem);border:0;border-radius:999px;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem;min-height:48px;padding:.85rem 1.5rem;transition:transform .15s ease,background .15s ease,border-color .15s ease}
  .tourpage .btn-go{background:var(--gold);color:var(--ink)}
  .tourpage .btn-go:hover{background:#f3b658;transform:translateY(-1px)}
  .tourpage .btn-go .price{font-weight:800}
  .tourpage .btn-ghost{color:var(--sand);background:transparent;border:1px solid rgba(244,239,227,.3)}
  .tourpage .btn-ghost:hover{border-color:var(--sand);transform:translateY(-1px)}
  .tourpage .meta-line{display:flex;flex-wrap:wrap;gap:.55rem .9rem;align-items:center;margin-top:1.9rem;padding-top:1.5rem;border-top:1px solid rgba(244,239,227,.28);font-size:clamp(.78rem,.72rem + .12vw,.9rem);letter-spacing:.1em;text-transform:uppercase;color:rgba(244,239,227,.82)}
  .tourpage .meta-line span{display:inline-flex;align-items:center;gap:.9rem}
  .tourpage .meta-line span::after{content:"";width:5px;height:5px;border-radius:50%;background:var(--gold)}
  .tourpage .meta-line span:last-child::after{display:none}

  /* ABOUT */
  .tourpage .about{background:var(--sand);color:var(--ink);padding-block:var(--pad-sec)}
  .tourpage .about .eyebrow{color:var(--olive)}
  .tourpage .about h2{font-family:var(--display);font-weight:700;font-size:var(--fs-h2);line-height:1.05;letter-spacing:-.02em;max-width:22ch;margin-bottom:.7rem}
  .tourpage .about .lede{font-size:var(--fs-lead);color:rgba(22,20,14,.66);max-width:60ch;margin-bottom:clamp(1.8rem,5vw,2.8rem)}
  .tourpage .grid{display:grid;grid-template-columns:1fr;gap:clamp(1rem,2.5vw,1.5rem)}
  .tourpage .card{background:var(--paper);border:1px solid rgba(22,20,14,.08);border-radius:16px;overflow:hidden;box-shadow:0 10px 30px -18px rgba(22,20,14,.3)}
  .tourpage .ph{aspect-ratio:4/3;background-color:#d9cdb5;background-size:cover;background-position:center}
  .tourpage .card-txt{padding:clamp(1rem,2.5vw,1.4rem)}
  .tourpage .card-txt h3{font-family:var(--display);font-weight:700;font-size:clamp(1.25rem,1.1rem + .4vw,1.6rem);margin-bottom:.3rem}
  .tourpage .card-txt p{font-size:var(--fs-body);color:rgba(22,20,14,.66)}
  .tourpage .cost-callout{margin-top:clamp(1.5rem,4vw,2.4rem);padding:1.1rem 1.3rem;background:rgba(110,133,78,.1);border:1px solid rgba(110,133,78,.28);border-radius:14px;font-size:var(--fs-body);color:var(--ink);max-width:60ch}
  .tourpage .cost-callout b{color:var(--olive)}
  .tourpage .about-cta{margin-top:clamp(1.6rem,4vw,2.2rem);display:flex;flex-wrap:wrap;align-items:center;gap:.8rem 1.1rem}
  .tourpage .about-cta .note{font-size:var(--fs-body);color:rgba(22,20,14,.62);max-width:46ch}
  @media (min-width:640px){ .tourpage .grid{grid-template-columns:1fr 1fr} }
  @media (min-width:980px){ .tourpage .grid{grid-template-columns:repeat(4,1fr)} }

  /* BOOKING */
  .tourpage .book{background:var(--sand-deep);color:var(--ink);padding-block:var(--pad-sec)}
  .tourpage .book .head{text-align:center;max-width:42rem;margin:0 auto clamp(1.6rem,4vw,2.4rem)}
  .tourpage .book .head .eyebrow{justify-content:center;color:var(--olive)}
  .tourpage .book .head .eyebrow::before{display:none}
  .tourpage .book .head h2{font-family:var(--display);font-weight:700;font-size:var(--fs-h2);line-height:1.05;letter-spacing:-.02em;margin-bottom:.6rem}
  .tourpage .book .head p{font-size:var(--fs-lead);color:rgba(22,20,14,.68)}
  .tourpage .book-card{width:100%;max-width:clamp(30rem,34vw,38rem);margin:0 auto;background:var(--paper);border-radius:22px;overflow:hidden;box-shadow:0 22px 60px -22px rgba(22,20,14,.4)}

  /* TICKET */
  .tourpage .ticket{color:var(--ink)}
  .tourpage .tk-body{padding:clamp(1.3rem,2.5vw,2rem) clamp(1.3rem,2.5vw,2rem) 0}
  .tourpage .label{font-size:clamp(.74rem,.7rem + .1vw,.85rem);letter-spacing:.14em;text-transform:uppercase;color:rgba(22,20,14,.6);font-weight:600;margin-bottom:.65rem}
  .tourpage .label.mt{margin-top:1.5rem}
  .tourpage .day-card{border:1.5px solid rgba(22,20,14,.14);border-radius:13px;overflow:hidden;margin-bottom:.55rem;transition:border-color .15s,background .15s}
  .tourpage .day-card.on{border-color:var(--olive);background:rgba(110,133,78,.08)}
  .tourpage .day-pick{display:flex;align-items:center;justify-content:space-between;gap:1rem;width:100%;text-align:left;cursor:pointer;font-family:var(--body);background:transparent;border:0;padding:.85rem 1.1rem;min-height:clamp(56px,50px + .5vw,66px)}
  .tourpage .dp-txt{display:flex;flex-direction:column;gap:.15rem}
  .tourpage .day-pick .day{font-weight:600;font-size:clamp(1.02rem,.98rem + .15vw,1.18rem);color:var(--ink)}
  .tourpage .day-pick .left{font-size:clamp(.8rem,.76rem + .1vw,.9rem);color:rgba(22,20,14,.6)}
  .tourpage .day-pick .tick{width:22px;height:22px;border-radius:6px;border:1.5px solid rgba(22,20,14,.22);display:grid;place-items:center;flex:none;transition:.15s}
  .tourpage .day-card.on .tick{background:var(--olive);border-color:var(--olive)}
  .tourpage .day-card.on .tick::after{content:"";width:6px;height:10px;border:2px solid #fff;border-top:0;border-left:0;transform:rotate(45deg) translateY(-1px)}
  .tourpage .day-pick:focus-visible{outline:2px solid var(--olive);outline-offset:-2px}
  .tourpage .day-qty{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.7rem 1.1rem;border-top:1px dashed rgba(22,20,14,.18)}
  .tourpage .day-qty[hidden]{display:none}
  .tourpage .day-qty .ql{font-size:.92rem;color:rgba(22,20,14,.72)}
  .tourpage .stepper{display:flex;align-items:center;gap:.7rem}
  .tourpage .stepper button{width:clamp(40px,38px + .4vw,46px);height:clamp(40px,38px + .4vw,46px);border-radius:50%;border:1.5px solid rgba(22,20,14,.18);background:var(--paper);font-size:1.3rem;line-height:1;cursor:pointer;color:var(--ink);display:grid;place-items:center;transition:.15s}
  .tourpage .stepper button:hover{border-color:var(--ink)}
  .tourpage .stepper .n{font-family:var(--display);font-weight:700;font-size:clamp(1.3rem,1.2rem + .3vw,1.6rem);min-width:1.4ch;text-align:center}
  .tourpage .fields{margin-top:.2rem}
  .tourpage .field{margin-bottom:.75rem}
  .tourpage .field > span.fl{display:block;font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(22,20,14,.6);font-weight:600;margin-bottom:.4rem}
  .tourpage .input{width:100%;border:1.5px solid rgba(22,20,14,.16);border-radius:11px;padding:.78rem .9rem;font-family:var(--body);font-size:1rem;color:var(--ink);background:#fff;min-height:48px;transition:border-color .15s}
  .tourpage .input::placeholder{color:rgba(22,20,14,.4)}
  .tourpage .input:focus{outline:2px solid var(--olive);outline-offset:0;border-color:var(--olive)}
  .tourpage .input.bad{border-color:var(--bad)}
  .tourpage .row2{display:flex;gap:.6rem}
  .tourpage .row2 .field{flex:1;margin-bottom:.75rem}
  .tourpage .phone{display:flex;gap:.5rem}
  .tourpage .phone .f-cc{flex:none;width:6.4rem;padding-inline:.55rem}
  .tourpage .phone .f-phone{flex:1}
  .tourpage .consent{display:flex;gap:.65rem;align-items:flex-start;margin:.5rem 0 .2rem;font-size:.88rem;line-height:1.45;color:rgba(22,20,14,.72);cursor:pointer}
  .tourpage .consent input{margin-top:.18rem;width:18px;height:18px;accent-color:var(--olive);flex:none}
  .tourpage .consent a{color:var(--olive);text-decoration:underline}
  .tourpage .tear{height:0;border-top:2px dashed rgba(22,20,14,.16);margin:1.4rem clamp(1.3rem,2.5vw,2rem) 0}
  .tourpage .tk-stub{padding:1.3rem clamp(1.3rem,2.5vw,2rem) clamp(1.4rem,2.5vw,2rem)}
  .tourpage .summary{list-style:none;display:flex;flex-direction:column;gap:.4rem;margin-bottom:.9rem}
  .tourpage .summary:empty{display:none}
  .tourpage .summary li{display:flex;justify-content:space-between;font-size:clamp(.92rem,.88rem + .1vw,1.02rem);color:rgba(22,20,14,.74)}
  .tourpage .summary li b{font-weight:600;color:var(--ink)}
  .tourpage .total{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1rem;padding-top:.7rem;border-top:1px solid rgba(22,20,14,.12)}
  .tourpage .total .t-label{color:rgba(22,20,14,.7);font-size:clamp(1rem,.95rem + .1vw,1.1rem);font-weight:600}
  .tourpage .total .amt{font-family:var(--display);font-weight:800;font-size:clamp(2rem,1.7rem + .6vw,2.7rem);letter-spacing:-.02em}
  .tourpage .total .amt .cur{color:var(--gold)}
  .tourpage .pay{width:100%;border:0;border-radius:999px;background:var(--gold);color:var(--ink);font-family:var(--body);font-weight:700;font-size:clamp(1.05rem,1rem + .2vw,1.22rem);padding:1rem;cursor:pointer;min-height:52px;transition:transform .15s,background .15s,opacity .15s}
  .tourpage .pay:hover:not(:disabled){background:#f3b658;transform:translateY(-1px)}
  .tourpage .pay:disabled{opacity:.45;cursor:not-allowed}
  .tourpage .trust{margin-top:.9rem;text-align:center;font-size:clamp(.82rem,.78rem + .1vw,.92rem);color:rgba(22,20,14,.6);line-height:1.6}
  .tourpage .trust b{color:var(--olive);font-weight:600}

  /* DETAILS */
  .tourpage .details{background:var(--sand);color:var(--ink);padding-block:var(--pad-sec)}
  .tourpage .details .eyebrow{color:var(--olive)}
  .tourpage .details h2{font-family:var(--display);font-weight:700;font-size:var(--fs-h2);line-height:1.05;letter-spacing:-.02em;margin-bottom:clamp(1.5rem,4vw,2.4rem)}
  .tourpage .det-grid{display:grid;grid-template-columns:1fr;gap:clamp(1.6rem,4vw,2.5rem)}
  @media (min-width:760px){ .tourpage .det-grid{grid-template-columns:repeat(3,1fr)} }
  .tourpage .det h3{font-family:var(--display);font-weight:700;font-size:1.2rem;margin-bottom:.8rem}
  .tourpage .det ul{list-style:none;display:flex;flex-direction:column;gap:.6rem}
  .tourpage .det li{position:relative;padding-left:1.25rem;font-size:var(--fs-body);color:rgba(22,20,14,.72);line-height:1.5}
  .tourpage .det li::before{content:"";position:absolute;left:0;top:.55em;width:6px;height:6px;border-radius:50%;background:var(--olive)}

  /* FOOTER */
  .tourpage .footer{background:var(--ink);color:rgba(244,239,227,.82);text-align:center;padding-block:clamp(2.5rem,6vw,4rem)}
  .tourpage .footer .mark{font-family:var(--display);font-weight:800;font-size:1.5rem;margin-bottom:.6rem}
  .tourpage .footer .mark span{color:var(--gold)}
  .tourpage .footer p{font-size:var(--fs-body);max-width:46ch;margin:0 auto .3rem}
  .tourpage .footer a{color:var(--gold);text-decoration:none;font-weight:600}
  .tourpage .footer a:hover{text-decoration:underline}
  .tourpage .footer .small{font-size:.85rem;color:rgba(244,239,227,.55);margin-top:.8rem}

  @media (prefers-reduced-motion:reduce){ .tourpage .reveal{opacity:1;transform:none;transition:none} }
</style>

<script>
  // Reveal-on-scroll
  const obs = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("in"); obs.unobserve(e.target); } }),
    { threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
  );
  document.querySelectorAll(".tourpage .reveal").forEach((el) => obs.observe(el));
</script>
