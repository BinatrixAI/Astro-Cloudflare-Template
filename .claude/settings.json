{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$(git branch --show-current)\" != \"main\" ] || { echo '{\"block\": true, \"message\": \"Cannot edit on main branch\"}' >&2; exit 2; }",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "web-performance-optimization@claude-skills": true,
    "web-performance-audit@claude-skills": true,
    "cloudflare-workers@claude-skills": true,
    "cloudflare-r2@claude-skills": true,
    "tailwind-v4-shadcn@claude-skills": true,
    "mcp-management@claude-skills": true
  }
}
